    "node": ">=0.10.0"
  },
  "typings": "./typings/survey-creator-js/entries/index.d.ts",
  "peerDependencies": {
    "ace-builds": "^1.4.12",
    "survey-core": "2.5.30",
    "survey-js-ui": "2.5.30",
    "survey-creator-core": "2.5.30",
    "@types/react-dom": "*",
    "@types/react": "*"
  },
  "exports": {
    ".": {
      "types": "./typings/survey-creator-js/entries/index.d.ts",
